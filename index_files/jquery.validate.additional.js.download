jQuery.validator.addMethod("chkCurrentDate", function (value, element, param) {
    
    var result = true;
    
    var currentDate =  new Date(new Date().toUTCString());
    currentDate.setHours(0);
    currentDate.setMinutes(0);
    currentDate.setSeconds(0);

    var dd = parseInt(value.substring(0, 2));
    var mm = parseInt(value.substring(3, 5));
    var yy = parseInt(value.substring(6, 10));

    var selectedDate = new Date(Date.UTC(yy, (mm - 1), dd));
    selectedDate.setHours(0);
    selectedDate.setMinutes(0);
    selectedDate.setSeconds(0);
   
    
    
    //if(isAnnual && currentDate > limitDate){
    //    result = false;
    //}
    //else
    if (selectedDate > currentDate ) {
        result = false;
    }
    else {
        result = true;
    }


    return result;
}, "The  date not valid.");

jQuery.validator.addMethod("chkCurrentDateLimit", function (value, element, param) {
    
    
    var result = false;
    var isDoCheck = param[0];
    var limitDays = param[1];
    
    if (isDoCheck) {
    var dd = parseInt(value.substring(0, 2));
    var mm = parseInt(value.substring(3, 5));
    var yy = parseInt(value.substring(6, 10));

    var selectedDate = new Date(Date.UTC(yy, (mm - 1), dd));

    var millisecondsPerDay = 24 * 60 * 60 * 1000;
    

    //get the limited date
    var currentDate = new Date(new Date().toUTCString());

    //var limitDate = currentDate.setDate(currentDate.getDate() + limitDays);
    var diffDays = (currentDate - selectedDate) / millisecondsPerDay;

    if (limitDays <= diffDays) {
        result = false;
    }
    else {
        result = true;
    }
}else{
        result = true;
}

    return result;
}, "The  date not valid.");

jQuery.validator.addMethod("chkDHOverEffectiveDate", function (value, element, param) {
    
    var result = false;
    var startDate = param[0];
    var limitDays = param[1];

    var dd = parseInt(value.substring(0, 2));
    var mm = parseInt(value.substring(3, 5));
    var yy = parseInt(value.substring(6, 10));

    var selectedDate = new Date(Date.UTC(yy, (mm - 1), dd));

    var limitDate = new Date(startDate);
    limitDate = limitDate.setDate(limitDate.getDate() + limitDays);
    
    if (selectedDate < limitDate) {
        result = false;
    }
    else {
        result = true;
    }


    return result;
}, "The date not valid.");

jQuery.validator.addMethod("chkPADischargeDate", function (value, element, param) {
    
    var result = false;
    var admissionDateVal = param[0].val();
    var dayslimit = param[1];
   

    var dd = parseInt(value.substring(0, 2));
    var mm = parseInt(value.substring(3, 5));
    var yy = parseInt(value.substring(6, 10));

    var selectedDate = new Date(Date.UTC(yy, (mm - 1), dd));
    var admissionDate;
    var diffDays;
    if (admissionDateVal) {
        var dd = parseInt(admissionDateVal.substring(0, 2));
        var mm = parseInt(admissionDateVal.substring(3, 5));
        var yy = parseInt(admissionDateVal.substring(6, 10));

        admissionDate = new Date(Date.UTC(yy, (mm - 1), dd));
        var millisecondsPerDay = 24 * 60 * 60 * 1000;
        diffDays = (selectedDate - admissionDate) / millisecondsPerDay;
        
    }

    

    if (diffDays < dayslimit) {
        
        result = false;
        
    }
    else {
        
        result = true;
    }

    return result;
}, "The discharge date not valid.");

