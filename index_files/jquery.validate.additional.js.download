jQuery.validator.addMethod("chkPeriodDate", function (value, element, param) {
    //check the selected date had duplicated.
    var result = true;
    var gobalFormValidateFromElms = validateElms[param[0]].dateFromItems;
    var gobalFormValidateToElms = validateElms[param[0]].dateToItems;

    var dd = parseInt(value.substring(0, 2));
    var mm = parseInt(value.substring(3, 5));
    var yy = parseInt(value.substring(6, 10));

    var selectedDate = new Date(Date.UTC(yy, (mm - 1), dd));


    if (gobalFormValidateFromElms.length > 1 && gobalFormValidateToElms.length > 1) {
        
        for (var i = 0; i < gobalFormValidateFromElms.length; i++) {
            var currentObjName = jQuery(element).prop('name');
            var fromObjName = gobalFormValidateFromElms[i].prop('name');
            var toObjName = gobalFormValidateToElms[i].prop('name');

            var fromDateVal = gobalFormValidateFromElms[i].val();
            var toDateVal = gobalFormValidateToElms[i].val();

            var fdd = parseInt(fromDateVal.substring(0, 2));
            var fmm = parseInt(fromDateVal.substring(3, 5));
            var fyy = parseInt(fromDateVal.substring(6, 10));
            var fromDate = new Date(Date.UTC(fyy, (fmm - 1), fdd));

            var tdd = parseInt(toDateVal.substring(0, 2));
            var tmm = parseInt(toDateVal.substring(3, 5));
            var tyy = parseInt(toDateVal.substring(6, 10));
            var toDate = new Date(Date.UTC(tyy, (tmm - 1), tdd));
            
            if (currentObjName == fromObjName) break;
            if (currentObjName == toObjName) break;
                
            if (selectedDate <= toDate || fromDate >= selectedDate) {
                    result = false;
                    break;
                }
        }
    }

    return result;
}, "The date from date not valid.");

jQuery.validator.addMethod("chkLogin", function (value, element, param) {
    var result = false;
    var email = jQuery(param[0]).val();
    var password = jQuery(param[1]).val();
    var validateUrl = param[2];

        checkLogin(
             email,
             password,
             validateUrl,
             function (returnData) {
                 result = (returnData.result);
                 
                 chkLoginMsg = returnData.msg;
                 
             },
              function (jqXHR, exception) {
                  result = false;
              }
         );
        
    return result;
}, chkLoginMsgCallback);

jQuery.validator.addMethod("chkNameVal", function (value, element, param) {
    //check the amount is not empty.
    var result = true;
    var nameElms = param[0];
    if (nameElms.length > 1) {
        //handle the case when there is only one 
        for (var i = 0; i < nameElms.length; i++) {
            var currentObj = jQuery(element).prop('name');
            var amountobj = nameElms[i].prop('name');

            if (currentObj != amountobj) {
                if (value == nameElms[i].val()) {
                    result = false;
                    break;
                }
            }
        }
    }
    return result;
}, "The name not valid.");

