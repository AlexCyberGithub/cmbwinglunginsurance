//日期格式化 
Date.prototype.toString = function (format, loc) {
    var time = {};
    time.Year = this.getFullYear();
    time.TYear = ("" + time.Year).substr(2);
    time.Month = this.getMonth() + 1;
    time.TMonth = time.Month < 10 ? "0" + time.Month : time.Month;
    time.Day = this.getDate();
    time.TDay = time.Day < 10 ? "0" + time.Day : time.Day;
    time.Hour = this.getHours();
    time.THour = time.Hour < 10 ? "0" + time.Hour : time.Hour;
    time.hour = time.Hour < 13 ? time.Hour : time.Hour - 12;
    time.Thour = time.hour < 10 ? "0" + time.hour : time.hour;
    time.Minute = this.getMinutes();
    time.TMinute = time.Minute < 10 ? "0" + time.Minute : time.Minute;
    time.Second = this.getSeconds();
    time.TSecond = time.Second < 10 ? "0" + time.Second : time.Second;
    time.Millisecond = this.getMilliseconds();
    time.Week = this.getDay();

    var MMMArrEn = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    var MMMArr = ["一月", "二月", "三月", "四月", "五月", "六月", "七月", "八月", "九月", "十月", "十一月", "十二月"];
    var WeekArrEn = ["Sun", "Mon", "Tue", "Web", "Thu", "Fri", "Sat"];
    var WeekArr = ["星期日", "星期一", "星期二", "星期三", "星期四", "星期五", "星期六"];

    var oNumber = time.Millisecond / 1000;

    if (format != undefined && format.replace(/\s/g, "").length > 0) {
        if (loc != undefined && loc == "en") {
            MMMArr = MMMArrEn.slice(0);
            WeekArr = WeekArrEn.slice(0);
        }
        format = format
            .replace(/yyyy/ig, time.Year)
            .replace(/yyy/ig, time.Year)
            .replace(/yy/ig, time.TYear)
            .replace(/y/ig, time.TYear)
            .replace(/MMM/g, MMMArr[time.Month - 1])
            .replace(/MM/g, time.TMonth)
            .replace(/M/g, time.Month)
            .replace(/dd/ig, time.TDay)
            .replace(/d/ig, time.Day)
            .replace(/HH/g, time.THour)
            .replace(/H/g, time.Hour)
            .replace(/hh/g, time.Thour)
            .replace(/h/g, time.hour)
            .replace(/mm/g, time.TMinute)
            .replace(/m/g, time.Minute)
            .replace(/ss/ig, time.TSecond)
            .replace(/s/ig, time.Second)
            .replace(/fff/ig, time.Millisecond)
            .replace(/ff/ig, oNumber.toFixed(2) * 100)
            .replace(/f/ig, oNumber.toFixed(1) * 10)
            .replace(/EEE/g, WeekArr[time.Week]);
    }
    else {
        format = time.Year + "-" + time.Month + "-" + time.Day + " " + time.Hour + ":" + time.Minute + ":" + time.Second;
    }
    return format;
}
// 计算两个日期的间隔天数  
function DateDiff(sDate1, sDate2) { //sDate1和sDate2是2002/12/18格式   
    var aDate, oDate1, oDate2, iDays
    sDate1 = sDate1.replace(/-/g, "/");
    sDate2 = sDate2.replace(/-/g, "/");
    aDate = sDate1.split("/")
    oDate1 = new Date(aDate[2] + '/' + aDate[1] + '/' + aDate[0]) //转换为dd/MM/yyyy格式   
    aDate = sDate2.split("/")
    oDate2 = new Date(aDate[2] + '/' + aDate[1] + '/' + aDate[0])
    //iDays = parseInt(Math.abs(oDate1 - oDate2) / 1000 / 60 / 60 / 24) //把相差的毫秒数转换为天数
    iDays = parseInt((oDate1 - oDate2) / 1000 / 60 / 60 / 24);
    return iDays
}

//香港身份證驗證
function checkHkid(sHKIDNum) {
    var iCheckSum;
    var iCheckDigit;
    var sCheckDigit;

    var sHKIDAlphabet2;
    var sHKIDNumber6;
    var i;
    check_flag = false;
    iCheckSum = 0;
    iCheckDigit = 0;
    sCheckDigit = "";

    //Normalize HKID number to XX999999X
    //sHKIDNum = UTrim(sHKIDNum)
    if (sHKIDNum.length == 8) {
        sHKIDNum = " " + sHKIDNum;
    }
    sHKIDAlphabet2 = sHKIDNum.substr(0, 2)
    sHKIDNumber6 = sHKIDNum.substr(2, 6)

    //check numberic and length
    if ((sHKIDNumber6 == sHKIDNumber6 - 0) && sHKIDNum.length == 9) {
        if (sHKIDAlphabet2.charAt(0) == " ") {
            iCheckDigit = 36;
        } else {
            var temp = sHKIDAlphabet2.charAt(0);
            iCheckDigit = temp.toUpperCase().charCodeAt(0) - 55;
        }

        iCheckSum = iCheckDigit * 9
        var temp = sHKIDAlphabet2.charAt(1);
        iCheckDigit = temp.toUpperCase().charCodeAt(0) - 55;
        iCheckSum = iCheckSum + iCheckDigit * 8

        for (i = 1; i <= 6; i++) {
            iCheckDigit = sHKIDNumber6.substr(i - 1, 1)
            iCheckSum = iCheckSum + iCheckDigit * (8 - i)
        }

        iCheckSum = 11 - iCheckSum % 11;

        if (iCheckSum < 10) {
            sCheckDigit = iCheckSum.toString();
        } else {
            if (iCheckSum == 10) {
                sCheckDigit = "A";
            } else {
                sCheckDigit = "0";
            }
        }

        if (sCheckDigit == sHKIDNum.substr(8, 1)) {
            check_flag = true;
        } else {
            check_flag = false;
        }

        return check_flag;
    } else {
        return check_flag;
    }
}


function checkEmail(email, validateUrl, successCallback, errorCallback) {
    jQuery.ajax({
        type: "POST",
        async: false,
        url: validateUrl,
        //url: document.location.origin + "/Common/AjaxGetJobOccupationList",
        data: { RegEmail: email },
        dataType: "text",
        success: successCallback,
        error:errorCallback
    });
    return false;
}


var chkLoginMsg = "";
function chkLoginMsgCallback() {
    return chkLoginMsg;
}
function checkLogin(email, password, validateUrl, successCallback, errorCallback) {
    jQuery.ajax({
        type: "POST",
        async: false,
        url: validateUrl,
        //url: document.location.origin + "/Common/AjaxGetJobOccupationList",
        data: {
            RegEmail: email,
            Password: password,
            __RequestVerificationToken: jQuery('input[name="__RequestVerificationToken"]').val()
        },
        dataType: "json",
        success: successCallback,
        error: errorCallback
    });
    return false;
}



function ValidateCaptcha(textInput, validateUrl, successCallback, errorCallback){
    jQuery.ajax({
        type: "POST",
        async:false,
        url: validateUrl,
        data: { captcha: textInput },
        dataType: "text",
        success: successCallback,
        error: errorCallback
        });
}
//將香港身份證驗證加入到jquery
jQuery.validator.addMethod("checkHkId", function (value, element) {
    if (jQuery.trim(value) != "") {
        value = value.toUpperCase();
        
        return checkHkid(value);
    } else {
        return false;
    }
}, "Please enter a valid HKID.");

jQuery.validator.addMethod("checkPassport", function (value, element) {
    if (jQuery.trim(value) != "") {
        value = value.toUpperCase();

        return /^[A-Za-z0-9]{6,}$/.test(value);
    } else {
        return false;
    }
}, "Please enter a valid Passport.");

//將香港身份證驗證加入到jquery
jQuery.validator.addMethod("HKIDRequired", function (value, element, param) {
    if ($(param[1]).is(":visible")) {
        var value1 = $(param[0]).val();
        var value2 = $(param[1]).val();

        if (jQuery.trim(value1) != "" && jQuery.trim(value2) != "") {
            value2 = value2.toUpperCase();
            $(param[2]).val(value1 + value2);
            return true;
        } else {
            return false;
        }
    } else {
        return true;
    }
}, "Please enter a valid HKID.");

jQuery.validator.addMethod("minHomeAmount", function (value, element, param) {

    var min = param[0];
    var checkbox = param[1];
    
    if (checkbox.is(":checked")) {
        var inputAmount = value.trim();
        inputAmount = inputAmount.replace(',', '');
        if (jQuery.isNumeric(inputAmount)) {
            inputAmount = Number(inputAmount).toFixed(2);
            //update the element value without ','
            jQuery(element).val(inputAmount);
            if (inputAmount < min || inputAmount < 0) {
                return false;
            } else {
                return true;
            }
        } else {
            //not a number.
            return false;
        }
    } else {
        //not selected.
        return true;
    }

}, "min amount is invalid.");

jQuery.validator.addMethod("notEqual", function (value, element, param) {
    
    var targetElem = param[0];

    if (targetElem.val() == value) {
        return false;
        } else {
        return true;
        }
   
}, "The value had duplicated.");

jQuery.validator.addMethod("maxHomeAmount", function (value, element, param) {

    var max = param[0];
    var checkbox = param[1];
    
    if (checkbox.is(":checked")) {
        var inputAmount = value.trim();
        inputAmount = inputAmount.replace(',', '');
        if (jQuery.isNumeric(inputAmount)) {
            inputAmount = Number(inputAmount).toFixed(2);
            //update the element value without ','
            jQuery(element).val(inputAmount);
            if (inputAmount > max) {
                return false;
            } else {
                return true;
            }
        } else {
            //not a number.
            return false;
        }
    } else {
        //not selected.
        return true;
    }
}, "max amount is invalid");

jQuery.validator.addMethod("HKIDDupulicated", function (value, element, param) {
    if (typeof (param) != 'undefined') {
        //first object should be one of insured value
        var isOneOfInusred = 'false';
        if (jQuery(param[0]).length) {
            isOneOfInusred = jQuery(param[0]).val();
        }
        //the first item will be 1.
        var startIdx = 1;
        if (isOneOfInusred == 'true') {
            startIdx = 2;
        }
        for (var i = startIdx; i < param.length; i++) {
            var hkidElement =jQuery(param[i]).val();
            if (hkidElement.toUpperCase() === value.toUpperCase()) {
                return false;
            }
        }
        return true;

    } else {
        return false;
    }
}, "The HKID had duplicated.");

//验证英文
jQuery.validator.addMethod("english", function (value, element) {
    return this.optional(element) || /^[A-Z a-z]*$/.test(value);
}, "Please enter a valid english.");

jQuery.validator.addMethod("AlphabetNumber", function (value, element) {
    //return this.optional(element) || /^[A-Z- a-z0-9]*$/.test(value);
    return this.optional(element) || /^[A-Za-z0-9-/()]*$/.test(value);
}, "Please enter a valid english and number.");

jQuery.validator.addMethod("EnglishChinese", function (value, element) {
    //return this.optional(element) || /^[A-Z- a-z0-9]*$/.test(value);
    return this.optional(element) || /^[\u3300-\u9fff\uf900-\ufaff A-Za-z]*$/.test(value);
}, "Please enter a valid english and chinese.");

jQuery.validator.addMethod("englishString", function (value, element) {
    return this.optional(element) || /^[A-Za-z0-9_()\-&.',\s ]*$/.test(value);
}, "Please enter a valid english.");

