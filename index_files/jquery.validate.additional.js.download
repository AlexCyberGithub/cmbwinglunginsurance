jQuery.validator.addMethod("DependFieldMandatoryForText", function (value, element, param) {
    if ($(param[0]).val() != "null") {
        return jQuery.trim(value) != "";
    }
    else {
        return true;
    }
}, "Please select a value.");

jQuery.validator.addMethod("DependFieldMandatory", function (value, element, param) {
    if ($(param[0]).val() != "null") {
        return jQuery.trim(value) != "0";
    }
    else {
        return true;
    }
}, "Please select a value.");

jQuery.validator.addMethod("selectRequired", function (value, element) {
    return value != "0";
}, "Please select a value.");

jQuery.validator.addMethod("selectValueMinLength", function (value, element, param) {
    var minlength = param[0];
    return value.length >= minlength;
}, "select cannot min length.");

jQuery.validator.addMethod("LessThanEqual", function (value, element, param) {
    var targetValue = param[0].val();
    if (!targetValue) {
        return true;
    }
    return parseFloat(value) <= parseFloat(targetValue);
}, "select must less than target.");

jQuery.validator.addMethod("DependChekcBoxMandatoryForText", function (value, element, param) {
    //var idChose = $("input[name='ReceivePromotionInfo2']:checked");
    var idChose = $(param[0] + ":checked");
    if (idChose.is(":checked")) {
        return jQuery.trim(value) != "";
    }
    else {
        return true;
    }
}, "Please Enter a value.");

jQuery.validator.addMethod("passwordFormat", function (value, element) {
    //    var re = /^(?!\D+$)(?![^a-z]+$)([^A-Z]+$)\S{8}$/;
    //    return this.optional(element) || re.test(value);

    if (value.length < 8 || value.length > 20) return false;

    var reqMeetCnt = 0;

    if (/[A-Z]/.test(value)) { reqMeetCnt += 1; }
    if (/[a-z]/.test(value)) { reqMeetCnt += 1; }
    if (/\d/.test(value)) { reqMeetCnt += 1; }
    if (/[$-/:-?{-~!"^_`\[\]]/.test(value)) { reqMeetCnt += 1; }

    return reqMeetCnt >= 3;

}, "Please enter a valid password strength.");

jQuery.validator.addMethod("rValidateTel", function (value, element) {
    // 获取当前选择的国家
    var country = jQuery(element).intlTelInput("getSelectedCountryData");
        
    // 如果是香港地区，使用自定义验证规则
    if (country.iso2.toUpperCase() === "HK") {
        // 自定义香港手机号码验证规则
        var hkPattern = /^\d{4}\s?\d{4}$/;
        return hkPattern.test(value);
    }

    // 其他地区使用默认验证
    return jQuery(element).val().length == 0 || jQuery(element).intlTelInput("isValidNumber");
}, "please input the valid phone number.");

jQuery.validator.addMethod("validPrefix", function (value, element, param) {
    if (jQuery.trim(value) != "")
        value = value.toUpperCase();

    var validPrefix = param[0];
    var prefix = validPrefix.split(",");
    for (var i = 0; i < prefix.length; i++) {
        if (value.startsWith(prefix[i])) {
            return true;
        }
    }
    return false;
}, "Please Enter a value.");

jQuery.validator.addMethod("validAmount", function (value, element) {
    if (value.length > 8) return false;

    var reg = /^(([1-9][0-9]*)|(([0]\.\d{1,2}|[1-9][0-9]*\.\d{1,2})))$/;
    if (reg.test(value) == false)
        return false;

    if (parseFloat(value) > 20000)
        return false;

    return true;

}, "please input the valid Amount.");