    if (jQuery.isNumeric(value) && value > 0) {
        if (jQuery.isNumeric(priceAmtVal) && priceAmtVal > 0
            && Number(value) > Number(priceAmtVal)) {
            result = false;
        }
    }

    return result;
}, "The currency code not valid.");


