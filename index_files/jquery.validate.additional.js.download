jQuery.validator.addMethod("chkDateMoreThanHr", function (value, element, param) {
    
    var result = false;
    var targetDateVal = param[0].val();
    var hour = param[1];
    //var isAnnual = param[2];
    //var limitDays = param[3];
    
    var dd = parseInt(value.substring(0, 2));
    var mm = parseInt(value.substring(3, 5));
    var yy = parseInt(value.substring(6, 10));
    var hh = parseInt(value.substring(11, 13));
    var mn = parseInt(value.substring(14, 16));
    

    var selectedDate = new Date(yy, (mm - 1), dd, hh, mn, 0);
    
    var targetDate;
    if (targetDateVal) {
        var t_dd = parseInt(targetDateVal.substring(0, 2));
        var t_mm = parseInt(targetDateVal.substring(3, 5));
        var t_yy = parseInt(targetDateVal.substring(6, 10));
        var t_hh = parseInt(targetDateVal.substring(11, 13));
        var t_mn = parseInt(targetDateVal.substring(14, 16));
        targetDate = new Date(t_yy, (t_mm - 1), t_dd, t_hh + hour, t_mn, 0);
    }
    
    
    //get the limited date
    //var currentDate = new Date(new Date().toUTCString());

    //var limitDate = currentDate.setDate(currentDate.getDate() + limitDays);

    //if(isAnnual && currentDate > limitDate){
    //    result = false;
    //}
    //else


    if (!targetDateVal) {
        result = true;
    }
    else if (targetDateVal && selectedDate < targetDate) {
        result = false;
    }
    else {
        result = true;
    }


    return result;
}, "The accident date not valid.");

jQuery.validator.addMethod("chkDateNotEarlierThanDays", function (value, element, param) {
    
    var result = false;
    var targetDateVal = "";
    var days = param[1];
    var admissionDate = param[2];

    if (param[0].length) {
        targetDateVal = param[0].val();
    }
    //var isAnnual = param[2];
    //var limitDays = param[3];

    var dd = parseInt(value.substring(0, 2));
    var mm = parseInt(value.substring(3, 5));
    var yy = parseInt(value.substring(6, 10));

    var selectedDate = new Date(Date.UTC(yy, (mm - 1), dd));
    var targetDate;
    var diffDays;

    if (!targetDateVal && admissionDate) {
        targetDateVal = admissionDate;
    }

    if (targetDateVal) {
        var dd = parseInt(targetDateVal.substring(0, 2));
        var mm = parseInt(targetDateVal.substring(3, 5));
        var yy = parseInt(targetDateVal.substring(6, 10));

        targetDate = new Date(Date.UTC(yy, (mm - 1), dd));

        var millisecondsPerDay = 24 * 60 * 60 * 1000;
        diffDays = (selectedDate - targetDate) / millisecondsPerDay;
        diffDays++;
    }
    
    if (!targetDateVal) {
        result = true;
    }
    else if (targetDateVal && diffDays < days) {
        result = false;
    }
    else {
        result = true;
    }


    return result;
}, "The accident date not valid.");

jQuery.validator.addMethod("chkCaptcha", function (value, element, param) {
    var result = false;
