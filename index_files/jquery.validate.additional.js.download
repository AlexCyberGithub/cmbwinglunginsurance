jQuery.validator.addMethod("englishAndNumber", function (value, element) {
    var re = /^(?!\D+$)(?![^a-zA-Z]+$)\S{8,20}$/;
    return this.optional(element) || re.test(value);// && $("#RegEmail").val() != value);
}, "Please enter a valid english and number.");

jQuery.validator.addMethod("chkBeMemberEmail", function (value, element, param) {
    var result = false;
    var becomeMemberChk = jQuery(param[0]).is(':checked');
