    var validateUrl = param[2];
    
    if (becomeMemberChk) {
       checkEmail(
            email,
            validateUrl,
            function (returnData) {
                result = (returnData == 'true');
            },
             function (jqXHR, exception) {
                 result = false;
             }
        );
    }
    else {
        result =  true;
    }
    
    return result;
}, "The email has already being use.");

jQuery.validator.addMethod("chkSelectedDate", function (value, element, param) {
    //check the selected date had duplicated.
    var result = true;
    var gobalFormValidateElms = validateElms[param[0]].dateItems;

    if (gobalFormValidateElms.length > 1) {
        //handle the case when there is only one 
        for (var i = 0; i < gobalFormValidateElms.length; i++) {
            var currentObj = jQuery(element).prop('name');
            var dateobj = gobalFormValidateElms[i].prop('name');

            if (currentObj != dateobj) {
                if (value == gobalFormValidateElms[i].val()) {
                    result = false;
                    break;
                }
            }
        }
    }

    return result;
}, "The selected date not valid.");



