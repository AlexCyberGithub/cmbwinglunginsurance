        ValidateCaptcha(
             textInput,
             validateUrl,
             function (returnData) {
                 result = (returnData == 'true');
             },
              function (jqXHR, exception) {
                  result = false;
              }
         );
        
    return result;
}, "The code is not valid.");

jQuery.validator.addMethod("passwordFormatNotRequired", function (value, element) {
    //    var re = /^(?!\D+$)(?![^a-z]+$)([^A-Z]+$)\S{8}$/;
    //    return this.optional(element) || re.test(value);

    if (value.length == 0) return true;
    if (value.length < 8) return false;

    if (/[A-Z]/.test(value))
        if (/[a-z]/.test(value))
            if (/\d/.test(value))
                return true;
    return false;


}, "Please enter a valid password strength.");

jQuery.validator.addMethod("passwordValidate", function (value, element) {
    //    var re = /^(?!\D+$)(?![^a-z]+$)([^A-Z]+$)\S{8}$/;
    //    return this.optional(element) || re.test(value);


    if ((value.length < 8) || (value.length > 20)) return false;
    var countOfValid = 0;

    if (/[A-Z]/.test(value)) {
        countOfValid++;
    }
    if (/[a-z]/.test(value)) {
        countOfValid++;
    }
    if (/\d/.test(value)) {
        countOfValid++;
    }

    if (/[-!$%^&*()_+|~=`{}\[\]:";'<>?,.\/]/.test(value)) {
        countOfValid++;
    }

    if (countOfValid >= 3) {
        return true;
    } else {
        return false;
    }

    return false;


}, "Please enter a valid password strength.");

jQuery.validator.addMethod("username", function (value, element) {
    return this.optional(element) || /^[\u0391-\uFFE5\w]+$/.test(value);
}, "Please enter a valid username.");

jQuery.validator.addMethod("chinese", function (value, element) {
    return this.optional(element) || /^[\u4E00-\u9FA5]+$/.test(value); //(/[^\u4E00-\u9FA5]/g,')
}, "Please enter a valid chinese.");

jQuery.validator.addMethod("NumNoDecimal", function (value, element) {
    if (value != "")
    return this.optional(element) || /^[0-9]+$/.test(value); //(/[^\u4E00-\u9FA5]/g,')
}, "Please enter a valid phone number.");

jQuery.validator.addMethod("phone", function (value, element) {
    if (value != "")
        var temp = value.substr(0, 1);
    return this.optional(element) || /^\d{8,8}$/.test(value) && (temp == "5" || temp == "6" || temp == "8" || temp == "9"); //(/[^\u4E00-\u9FA5]/g,')
}, "Please enter a valid phone number.");

jQuery.validator.addMethod("phoneHome", function (value, element) {
    if (value != "")
        var temp = value.substr(0, 1);
    return this.optional(element) || /^\d{8,8}$/.test(value) && (temp == "2" || temp == "3" || temp == "5" || temp == "6" || temp == "8" || temp == "9"); //(/[^\u4E00-\u9FA5]/g,')
}, "Please enter a valid phone number.");

jQuery.validator.addMethod("cargoPhone", function (value, element) {
    return this.optional(element) || /^\d{8,}$/.test(value); //(/[^\u4E00-\u9FA5]/g,')
}, "Please enter a valid phone number.");

jQuery.validator.addMethod("maxNumber", function (value, element) {
    return this.optional(element) || (/^\d{1,2}$/.test(value) && value <= 10 && value > 0); //(/[^\u4E00-\u9FA5]/g,')
}, "Please enter a 1-10 number.");

jQuery.validator.addMethod("IsDate", function (value, element) {
    
    
    //value format is dd/MM/yyyy 
    if (value.length < 10) return false;
    var y = value.substring(0, 4);
    var m = value.substring(5, 7);//.trimStart("0");
    var d = value.substring(8, 10);//.trimStart("0");

    var intY = parseInt(y);
    var intM = parseInt(m);
    var intD = parseInt(d);

    if (intY > 2200 || intY < 1800) return false;
    if (intM > 12 || intM < 1) return false;
    if (intD > 31 || intD < 1) return false;

    var thisdate = new Date(y + "/" + m + "/" + d);
    return !/Invalid|NaN/.test(thisdate) && 
        (thisdate.getFullYear() == intY && (thisdate.getMonth() + 1) == intM && thisdate.getDate() == intD)
        ;
}, "Please enter a valid Date.");

jQuery.validator.addMethod("MaxDOB", function (value, element) {
    //value format is dd/MM/yyyy 
    if (value.length < 10) return false;

    var today = new Date();
    var dateBirthday = new Date(value.substring(6, 10) + "/" + value.substring(3, 5) + "/" + value.substring(0, 2));

    return this.optional(element) || !(dateBirthday > today);
}, "Please enter a valid Date.");

jQuery.validator.addMethod("validDateRange", function (value, element, param) {
    var minValue = 0;
    var maxValue = 1;
    var selectDate = value;
    var today = param[1];

    if (selectDate.length < 10 || today < 10) return true;
    //最大年龄计算使用
    var dateToday = new Date(today.substring(6, 10), today.substring(3, 5), today.substring(0, 2));
    var dateBirthday = new Date(selectDate.substring(6, 10), selectDate.substring(3, 5), selectDate.substring(0, 2));
    //最小年龄计算使用
    var dateToday2 = new Date(today.substring(6, 10), today.substring(3, 5), today.substring(0, 2));
    var dateBirthday2 = new Date(selectDate.substring(6, 10), selectDate.substring(3, 5), selectDate.substring(0, 2));

    if (param.length == 4) {

        if (param[0].toLowerCase() == "days") {

            //最小天数
            minValue = parseInt(param[2]);
            //最大天数
            maxValue = parseInt(param[3]);

            //计算两个日期相差天数
            var currDays = DateDiff(selectDate, today);//包括当天需要+1
            return this.optional(element) || (currDays >= minValue && currDays <= maxValue);
        }
    }
}, "Date is out of range");

jQuery.validator.addMethod("validAge", function (value, element, param) {
    //var minDays = 42;//默认6周
    //var minYears = 18;//默认18岁
    //var maxYears = 75;//默认75岁
    var minChildAge = 42;
    var maxChildAge = 17;
    var minAudltAge = 18;
    var maxAudltAge = 75;
    var birthday = value;
    var today = param[1];

    if (birthday.length < 10 || today < 10) return true;

    var RealdateBirthday = new Date(birthday.substring(6, 10), birthday.substring(3, 5) - 1, birthday.substring(0, 2));
    //最大年龄计算使用
    var dateToday = new Date(today.substring(6, 10), today.substring(3, 5) - 1, today.substring(0, 2));
    var dateBirthday = new Date(birthday.substring(6, 10), birthday.substring(3, 5) - 1, birthday.substring(0, 2));
    //最小年龄计算使用
    var dateToday2 = new Date(today.substring(6, 10), today.substring(3, 5) - 1, today.substring(0, 2));
    var dateBirthday2 = new Date(birthday.substring(6, 10), birthday.substring(3, 5) - 1, birthday.substring(0, 2));

    if (param.length == 4) {

        if (param[0].toLowerCase() == "child") {

            //最小年龄 
            var minAge = param[2];
            var temp = minAge.substr(minAge.length - 1, 1);
            if (minAge == "0") {
                minChildAge = parseInt(minAge);
            }
            else if (temp.toLowerCase() == "w") {//按星期算(以w结尾)
                minAge = minAge.substr(0, minAge.length - 1);
                minChildAge = parseInt(minAge) * 7;
            }
            else if (temp.toLowerCase() == "d") {//按天数算(以d结尾)
                minAge = minAge.substr(0, minAge.length - 1);
                minChildAge = parseInt(minAge);
            }
            else if (temp.toLowerCase() == "m") {//按月计算(以m结尾)
                minAge = minAge.substr(0, minAge.length - 1);
                minChildAge = parseInt(minAge);
            }
            else {//格式错误默认设为0
                minChildAge = 0;
            }

            //最大年龄
            maxChildAge = parseInt(param[3]);

            if (temp.toLowerCase() == "m") {

                //计算最小月数
                var currMonth = (dateToday2.getFullYear() * 12 + dateToday2.getMonth()) - (dateBirthday2.getFullYear() * 12 + dateBirthday2.getMonth());
                dateBirthday2.setFullYear(dateToday2.getFullYear());
                dateBirthday2.setMonth(dateToday2.getMonth());
                if (dateToday2 < dateBirthday2) {
                    currMonth--;
                }

                //计算最大年数
                var currYears = dateToday.getFullYear() - dateBirthday.getFullYear();
                // Reset birthday to the current year.
                dateBirthday.setFullYear(dateToday.getFullYear());

                // If the user's birthday has not occurred yet this year, subtract 1.
                if (dateToday < dateBirthday) {
                    currYears--;
                }


                return this.optional(element) || (currMonth >= minChildAge && currYears < maxChildAge && RealdateBirthday < new Date());
            }
            else {
                //计算最小天数
                var currDays = DateDiff(today, birthday) + 1;//包括当天需要+1


                //计算最大年数
                var currYears = dateToday.getFullYear() - dateBirthday.getFullYear();
                // Reset birthday to the current year.
                dateBirthday.setFullYear(dateToday.getFullYear());

                // If the user's birthday has not occurred yet this year, subtract 1.
                if (dateToday < dateBirthday) {
                    currYears--;
                }

                return this.optional(element) || (currDays >= minChildAge && currYears < maxChildAge && RealdateBirthday < new Date());
            }
        }
        else if (param[0].toLowerCase() == "friend") {
            //最小年龄 
            var minAge = param[2];
            var temp = minAge.substr(minAge.length - 1, 1);
            if (minAge == "0") {
                minChildAge = parseInt(minAge);
            }
            else if (temp.toLowerCase() == "w") {//按星期算(以w结尾)
                minAge = minAge.substr(0, minAge.length - 1);
                minChildAge = parseInt(minAge) * 7;
            }
            else if (temp.toLowerCase() == "d") {//按天数算(以d结尾)
                minAge = minAge.substr(0, minAge.length - 1);
                minChildAge = parseInt(minAge);
            }
            else if (temp.toLowerCase() == "m") {//按月计算(以m结尾)
                minAge = minAge.substr(0, minAge.length - 1);
                minChildAge = parseInt(minAge);
            }
            else {//格式错误默认设为0
                minChildAge = 0;
            }

            //最大年龄
            maxAudltAge = parseInt(param[3]);

            if (temp.toLowerCase() == "m") {

                //计算最小月数
                var currMonth = (dateToday2.getFullYear() * 12 + dateToday2.getMonth()) - (dateBirthday2.getFullYear() * 12 + dateBirthday2.getMonth());
                dateBirthday2.setFullYear(dateToday2.getFullYear());
                dateBirthday2.setMonth(dateToday2.getMonth());
                if (dateToday2 < dateBirthday2) {
                    currMonth--;
                }

                //计算最大年数
                var currYears = dateToday.getFullYear() - dateBirthday.getFullYear();
                // Reset birthday to the current year.
                dateBirthday.setFullYear(dateToday.getFullYear());

                // If the user's birthday has not occurred yet this year, subtract 1.
                if (dateToday < dateBirthday) {
                    currYears--;
                }

                return this.optional(element) || (currMonth >= minChildAge && currYears < maxAudltAge && RealdateBirthday < new Date());
            }
            else {

                //计算最小天数
                var currDays = DateDiff(today, birthday) + 1;//包括当天需要+1


                //计算最大年数
                var currYears = dateToday.getFullYear() - dateBirthday.getFullYear();
                // Reset birthday to the current year.
                dateBirthday.setFullYear(dateToday.getFullYear());

                // If the user's birthday has not occurred yet this year, subtract 1.
                if (dateToday < dateBirthday) {
                    currYears--;
                }

                return this.optional(element) || (currDays >= minChildAge && currYears < maxAudltAge && RealdateBirthday < new Date());
            }
        }
        else {//成年人

            minAudltAge = parseInt(param[2]);
            maxAudltAge = parseInt(param[3]);
            if (maxAudltAge == 0) {

                var years = dateToday.getFullYear() - dateBirthday.getFullYear();

                // Reset birthday to the current year.
                dateBirthday.setFullYear(dateToday.getFullYear());

                // If the user's birthday has not occurred yet this year, subtract 1.
                if (dateToday < dateBirthday) {
                    years--;
                }
                return this.optional(element) || years >= minAudltAge;
            }
            else {
                var currYears = dateToday.getFullYear() - dateBirthday.getFullYear();

                // Reset birthday to the current year.
                dateBirthday.setFullYear(dateToday.getFullYear());

                // If the user's birthday has not occurred yet this year, subtract 1.
                if (dateToday < dateBirthday) {
                    currYears--;
                }
                return this.optional(element) || (currYears >= minAudltAge && currYears < maxAudltAge);
            }

        }

    }
}, "Age is out of range.");

jQuery.validator.addMethod("CheckAge18", function (value, element) {
    //value format is dd/MM/yyyy 
    if (value.length < 10) return false;


    //var now = new Date();
    //var today = new Date(now.getUTCFullYear(),now.getUTCMonth(),now.getUTCDay());
    //var minAgeDate = new Date((today.getFullYear() - 18), today.getMonth(), today.getDate());
    var today = new Date(new Date().toUTCString());
    var todayYear = today.getFullYear();
    var todayDate = today.getDate();
    var todayMonth = today.getMonth();
    var minAgeDate = new Date(Date.UTC((todayYear - 18), todayMonth, todayDate,0,0,0,0));
    //var dateBirthday = new Date(value.substring(6, 10) + "/" + value.substring(3, 5) + "/" + value.substring(0, 2));
    var dateBirthday = new Date(value.substring(0, 4) + "/" + value.substring(5, 7) + "/" + value.substring(8, 10));

    return dateBirthday <= minAgeDate;
}, "Age should be over 18.");

jQuery.validator.addMethod("CheckAge", function (value, element, param) {
    //value format is dd/MM/yyyy 
    if (value.length < 10) return false;
    
    var minAge = parseInt(param[0]);
    var maxAge = parseInt(param[1]);
    var effectiveDateStr = param[2];
    //from DB format yyyy-MM-dd
    var yy = parseInt(effectiveDateStr.substring(0, 4));
    var mm = parseInt(effectiveDateStr.substring(5, 7)) - 1;
    var dd = parseInt(effectiveDateStr.substring(8, 10));
    //var effectiveDate = new Date(Date.UTC(yy, (mm - 1), dd));
    
    var minAgeDate = new Date(Date.UTC((yy - minAge), mm, dd,0,0,0,0));
    var maxAgeDate = new Date(Date.UTC((yy - maxAge), mm, dd, 0, 0, 0, 0));
    //var dateBirthday = new Date(value.substring(6, 10) + "/" + value.substring(3, 5) + "/" + value.substring(0, 2));
    var dateBirthday = new Date(value.substring(0, 4) + "/" + value.substring(5, 7) + "/" + value.substring(8, 10));
    
    if (maxAge == -1) {
        return (dateBirthday <= minAgeDate);
    } else {
        return ((dateBirthday <= minAgeDate) && !(dateBirthday <= maxAgeDate));
    }
    
}, "Date of birth not in range.");

// 专用于旅行保险的年龄校验，支持18岁最小年龄和包含边界逻辑
jQuery.validator.addMethod("CheckAgeTravel", function (value, element, param) {
    // value format: yyyy-MM-dd
    if (value.length < 10) return false;

    var minAgeYears = parseInt(param[0]); // 18 岁
    var maxAgeYears = parseInt(param[1]);
    var effectiveDateStr = param[2]; // yyyy-MM-dd

    // 解析起保日（UTC）
    var effY = parseInt(effectiveDateStr.substring(0, 4));
    var effM = parseInt(effectiveDateStr.substring(5, 7)) - 1;
    var effD = parseInt(effectiveDateStr.substring(8, 10));
    var effectiveDateUtc = new Date(Date.UTC(effY, effM, effD, 0, 0, 0, 0));

    // 解析生日（UTC，避免本地时区影响）
    var dobY = parseInt(value.substring(0, 4));
    var dobM = parseInt(value.substring(5, 7)) - 1;
    var dobD = parseInt(value.substring(8, 10));
    var dobUtc = new Date(Date.UTC(dobY, dobM, dobD, 0, 0, 0, 0));

    // 按"年"判断最小年龄：生日 + minAgeYears 年 ≤ 起保日（含边界）
    var minAgeDateUtc = new Date(Date.UTC(dobUtc.getUTCFullYear() + minAgeYears, dobUtc.getUTCMonth(), dobUtc.getUTCDate(), 0, 0, 0, 0));
    var minAgeOk = effectiveDateUtc.getTime() >= minAgeDateUtc.getTime();

    // 最大年龄按"日期比较"：起保日 ≤ 生日 + maxAge 年（含当天）
    var maxAgeOk = true;
    if (!isNaN(maxAgeYears) && maxAgeYears !== -1) {
        var maxAgeDateUtc = new Date(Date.UTC(dobUtc.getUTCFullYear() + maxAgeYears, dobUtc.getUTCMonth(), dobUtc.getUTCDate(), 0, 0, 0, 0));
        maxAgeOk = effectiveDateUtc.getTime() <= maxAgeDateUtc.getTime();
    }

    return minAgeOk && maxAgeOk;
}, "Date of birth not in range.");

//验证被保险人HKID 是否重复,param传入要验证的文本框个数
jQuery.validator.addMethod("CheckRepeat", function (value, element, param) {
    var arr = new Array();
    var arr2 = new Array();

    if ($("#ApplicantAndInsuredAreSame").val() == undefined) {
        arr2.push("#HKID");
        arr.push($("#HKID1").val().toUpperCase() + $("#HKID2").val());
    }

    var num = parseInt(param[0]);
    var currHKID = param[1];

    for (var i = 0; i < num; i++) {
        if ($("#InsuredDetails_" + i + "__HKID1").val() != undefined) {
            var hkID1 = $("#InsuredDetails_" + i + "__HKID1").val().toUpperCase();
            var hkID2 = $("#InsuredDetails_" + i + "__HKID2").val();
            arr2.push("#InsuredDetails_" + i + "__HKID");
            arr.push(hkID1 + hkID2);
        }
    }

    var isRepeat = false;
    for (var i = 0; i < arr.length - 1; i++) {
        if (arr2[i] != currHKID) {
            if (arr[i] == value.toUpperCase()) {
                isRepeat = true;
            }
        }
    }

    //!(/(\x0f[^\x0f]+)\x0f[\s\S]*\1/.test("\x0f" + arr.join("\x0f\x0f") + "\x0f"))
    return this.optional(element) || !isRepeat;
}, "HKID is repeat.")


