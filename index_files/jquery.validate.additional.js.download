jQuery.validator.addMethod("selectAmtCodeRequired", function (value, element, param) {
    //check the currency code is selected.
    
    var result = true;
    var mustValid = param[0];
    var gobalFormValidateElms = validateElms[param[1]].codeItems;

    if (gobalFormValidateElms.length == 1) {
        //check when the amount had value.
        if (!mustValid) {
            var amountElm = jQuery(element).parent().next('input.decimal');
            if (jQuery.isNumeric(amountElm.val()) && amountElm.val() > 0) {
                if (value == '0') {
                    result = false;
                }
            }
        }
    } else {
        if (value == '0') {
            result = false;
        }
    }

    if (mustValid) {
        if (value == '0') {
            result = false;
        }
    }

    
    return result;
}, "The currency code not valid.");






