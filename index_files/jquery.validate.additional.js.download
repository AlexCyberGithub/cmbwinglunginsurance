jQuery.validator.addMethod("priceCodeEqualTo", function (value, element, param) {
    //check the currency code is selected.
    var result = true;
    var priceCodeVal = jQuery(param[0]).val();
    var amtVal = jQuery(param[1]).val();

    if (jQuery.isNumeric(value) && jQuery.isNumeric(priceCodeVal)
        && priceCodeVal > 0
        && jQuery.isNumeric(amtVal)) {
        if (Number(value) == 0 || priceCodeVal > 0 && value != priceCodeVal) {
            result = false;
        }
    }

    return result;
}, "The currency code not valid.");

